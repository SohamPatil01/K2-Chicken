# =============================================================================
# Local development: copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).
#
# Vercel: you do NOT upload this file. Add each variable in the dashboard:
#   Vercel → your Project → Settings → Environment Variables
#   Create one row per variable (Name = left column below, Value = your secret).
#   Enable at least "Production"; also enable "Preview" if you want preview
#   deployments to use the DB. Then redeploy (Deployments → … → Redeploy).
#
# Optional CLI: `vercel env pull .env.local` after `vercel link` (pulls remote
# env into a local file for testing — still do not commit that file).
# =============================================================================

# --- Required on Vercel (build + runtime) ---
# Postgres connection string from Neon, Supabase, Railway, Vercel Postgres, etc.
# Use SSL when your host requires it, e.g. append: ?sslmode=require
# Example (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Strongly recommended in production ---
# Used for customer login, orders API, addresses JWT
JWT_SECRET=

# Admin dashboard login (if you use env-based admin user)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Public / browser (NEXT_PUBLIC_* are exposed to the client) ---
# Canonical site URL for SEO and links (include https, no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Google Maps (contact + address picker). Same key often used server + client.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: server-only key for distance APIs if different from public key
GOOGLE_MAPS_API_KEY=

# Checkout UPI display
NEXT_PUBLIC_UPI_ID=

# --- Optional integrations ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
ADMIN_WHATSAPP_NUMBER=

# Protect one-off admin DB routes (init-db, migrate, etc.)
DB_INIT_TOKEN=

# POS integration
POS_API_KEY=

# Optional: skip the one-time DB ping on server boot (CI / local without Postgres)
# SKIP_DB_STARTUP_PROBE=1

# --- Local Postgres only (when DATABASE_URL is not set) ---
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_DB=chicken_vicken
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
